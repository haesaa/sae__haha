{
    "$schema": "quality-gates v1.0",
    "_description": "단계별 검증 기준. 자동 검증 + 정성 리뷰 기준 정의.",
    "gates": {
        "gate_T1": {
            "task": "T1 분석",
            "automated": [
                {
                    "check": "analysis_json_exists",
                    "description": "analysis.json 존재",
                    "condition": "file_size > 0"
                },
                {
                    "check": "bpm_range",
                    "description": "BPM 범위 (P1)",
                    "condition": "40 <= bpm <= 220"
                },
                {
                    "check": "sections_count",
                    "description": "구간 수 (P1)",
                    "condition": "sections >= 3"
                },
                {
                    "check": "beat_array_valid",
                    "description": "비트 배열 (P1)",
                    "condition": "beat_times.length > 0"
                },
                {
                    "check": "scene_count_match",
                    "description": "장면 수 매칭 (P2)",
                    "condition": "scenes >= conti_frames"
                },
                {
                    "check": "prompt_files_exist",
                    "description": "프롬프트 파일 수",
                    "condition": "prompt_count == scene_count"
                }
            ],
            "qualitative": []
        },
        "gate_T2": {
            "task": "T2 이미지 생성",
            "automated": [
                {
                    "check": "image_resolution",
                    "description": "이미지 해상도",
                    "condition": "width >= 1024 AND height >= 1024"
                },
                {
                    "check": "scene_count_match",
                    "description": "장면 수 매칭",
                    "condition": "image_count == scene_count"
                },
                {
                    "check": "file_format",
                    "description": "파일 형식",
                    "condition": "format IN ['PNG', 'JPG']"
                },
                {
                    "check": "file_size",
                    "description": "0바이트 체크",
                    "condition": "file_size > 0"
                }
            ],
            "qualitative": [
                {
                    "check": "character_consistency",
                    "description": "캐릭터 일관성",
                    "reviewer": "Leader"
                },
                {
                    "check": "mood_matching",
                    "description": "무드 매칭",
                    "reviewer": "Leader"
                }
            ]
        },
        "gate_T3": {
            "task": "T3 모션/영상 생성",
            "automated": [
                {
                    "check": "duration_accuracy",
                    "description": "영상 길이 오차",
                    "condition": "abs(actual - target) <= 0.5s"
                },
                {
                    "check": "resolution_match",
                    "description": "해상도 일치",
                    "condition": "resolution == T2_resolution"
                },
                {
                    "check": "codec_valid",
                    "description": "코덱 확인",
                    "condition": "codec == 'H.264'"
                },
                {
                    "check": "file_size",
                    "description": "0바이트 체크",
                    "condition": "file_size > 0"
                }
            ],
            "qualitative": [
                {
                    "check": "character_deformation",
                    "description": "캐릭터 변형도",
                    "reviewer": "Leader"
                },
                {
                    "check": "motion_naturalness",
                    "description": "모션 자연스러움",
                    "reviewer": "Leader"
                }
            ]
        },
        "gate_T4": {
            "task": "T4 오디오",
            "automated": [
                {
                    "check": "audio_file_exists",
                    "description": "오디오 파일 존재",
                    "condition": "file_count >= 1"
                },
                {
                    "check": "file_size",
                    "description": "0바이트 체크",
                    "condition": "file_size > 0"
                },
                {
                    "check": "codec_valid",
                    "description": "코덱 디코드 가능",
                    "condition": "codec IN ['MP3', 'AAC', 'WAV']"
                },
                {
                    "check": "duration_match",
                    "description": "길이 매칭",
                    "condition": "abs(actual - target) <= 1.0s"
                }
            ],
            "qualitative": []
        },
        "gate_T5": {
            "task": "T5 편집/합성",
            "automated": [
                {
                    "check": "beat_sync_accuracy",
                    "description": "비트 싱크 오차",
                    "condition": "max_offset <= 50ms"
                },
                {
                    "check": "total_duration",
                    "description": "총 길이",
                    "condition": "abs(actual - source) <= 1.0s"
                },
                {
                    "check": "resolution",
                    "description": "해상도",
                    "condition": "1920x1080"
                },
                {
                    "check": "codec",
                    "description": "코덱",
                    "condition": "H.264 + AAC"
                },
                {
                    "check": "file_size",
                    "description": "비정상 크기",
                    "condition": "file_size > 1MB"
                }
            ],
            "qualitative": [
                {
                    "check": "full_playback",
                    "description": "전체 재생 검수",
                    "reviewer": "Leader"
                }
            ]
        },
        "gate_QC": {
            "task": "최종 품질 검증",
            "automated": [
                {
                    "check": "file_integrity",
                    "description": "파일 무결성",
                    "condition": "file_exists AND size > 0"
                },
                {
                    "check": "nsfw_scan",
                    "description": "NSFW 스캔",
                    "condition": "sample_10_frames_all_safe"
                },
                {
                    "check": "metadata_stripped",
                    "description": "메타데이터 제거",
                    "condition": "no_exif_no_gps"
                },
                {
                    "check": "no_key_leakage",
                    "description": "API키 잔류 없음",
                    "condition": "no_pattern_match"
                }
            ],
            "qualitative": []
        }
    }
}